  }
  .callout-optional {
    background: #fffbf0;
    border-left: 3px solid #ff9500;
    color: #333;
  }
  .callout-optional .callout-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #ff9500;
    margin-bottom: 6px;
