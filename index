  /* ─── DIVIDER ─── */
  .divider { border: none; border-top: 1px solid #f0f0f0; margin: 24px 0; }

  /* ─── PRINT ─── */
  @media print {
    body { background: #fff; }
    .slide { margin-bottom: 0; box-shadow: none; }
    @page { margin: 0; size: A4 landscape; }
  }
</style>
