  .big-text { font-size: 16px; line-height: 1.6; color: #333; margin-bottom: 20px; }

  /* ─── CALLOUT-ПЛАШКИ ─── */
  .callout {
    border-radius: 6px;
    padding: 12px 16px;
    margin-top: 12px;
    margin-bottom: 4px;
    font-size: 12px;
    line-height: 1.5;
