  .callout-designer {
    background: #f0f5ff;
    border-left: 3px solid #007aff;
    color: #333;
  }
  .callout-designer .callout-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #007aff;
