  .case-metrics { display: flex; flex-direction: column; gap: 4px; }
  .case-metric { font-size: 12px; color: #555; }
  .case-metric .val-after { font-weight: 700; color: #111; }
  .case-metric .val-before { color: #bbb; text-decoration: line-through; margin-right: 4px; }
  .case-big-num { font-size: 28px; font-weight: 900; letter-spacing: -1px; line-height: 1; }
