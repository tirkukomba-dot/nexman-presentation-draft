  .contact-info { }
  .contact-name { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  .contact-role { font-size: 12px; color: #888; margin-bottom: 12px; }
  .contact-links { display: flex; flex-direction: column; gap: 4px; }
